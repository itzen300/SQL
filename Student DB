4. Display the record of the student whose CGPA is the lowest from the table.
code => SELECT * FROM student
WHERE CGPA = (SELECT MIN(CGPA) FROM student);

5. Display only those students whose CGPA lies in the range of [6, 8]
code => SELECT * FROM student
WHERE CGPA BETWEEN 6 AND 8;

6. Order the data in the tables based on CGPA from ascending to descending.
code =>SELECT * FROM student
ORDER BY CGPA DESC;

7. Display the records for students with the smallest and the largest CGPA
code =>-- Smallest CGPA
SELECT * FROM student
WHERE CGPA = (SELECT MIN(CGPA) FROM student);

-- Largest CGPA
